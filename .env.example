# ── Server ──────────────────────────────
PORT=3001

# ── SMTP (Gmail example) ─────────────────
# Para Gmail: activa "Contraseñas de aplicaciones" en tu cuenta Google
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_correo@gmail.com
SMTP_PASS=tu_app_password

# ── Destinatario ─────────────────────────
# A qué correo llegan los mensajes del formulario
MAIL_TO=info@andekgroup.com

# ── CORS ────────────────────────────────
# Origen permitido (deja * para desarrollo, pon tu dominio en producción)
FRONTEND_ORIGIN=*
